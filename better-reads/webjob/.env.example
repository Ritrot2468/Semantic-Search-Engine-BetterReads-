# MongoDB connection string (same as the backend)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bookdb?retryWrites=true&w=majority

# Google Books API key (optional — increases daily quota from 1,000 to 10,000 requests)
# Get one free at: https://console.cloud.google.com/ → APIs & Services → Books API
GOOGLE_BOOKS_API_KEY=

# How many genre queries to run per job execution (default: all 15)
# Reduce this if you want shorter runs during testing
MAX_GENRES=15

# Pages of results to fetch per genre (40 books/page, default: 5 = 200 books/genre)
PAGES_PER_GENRE=5
